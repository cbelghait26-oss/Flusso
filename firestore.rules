    rules_version = '2';
    service cloud.firestore {
    match /databases/{database}/documents {

        // ── Helpers ───────────────────────────────────────────────────────────────
        function signedIn() {
        return request.auth != null;
        }

        function isSelf(userId) {
        return request.auth != null && request.auth.uid == userId;
        }

        // ── Users ─────────────────────────────────────────────────────────────────
        // Root profile doc: readable by all signed-in users (needed for friend name
        // lookups), writable only by the owner.
        match /users/{userId} {
        allow read: if signedIn();
        allow write: if isSelf(userId);

        // ALL subcollections: objectives, tasks, calendarEvents, localEvents,
        // streak, focusDaily, focusSettings, focusSessions, setup, theme,
        // dailyGoal, trainingPlans, profilePicture, notifSettings, timeFormat24h,
        // achievements, private (settings, stats), etc.
        // The app stores each at  users/{uid}/{collection}/data  as a JSON blob.
        match /{collection}/{docId} {
            allow read, write: if isSelf(userId);
        }
        }

        // ── Friend tags ───────────────────────────────────────────────────────────
        // Top-level reverse-lookup: friendTag → uid.
        // Doc ID is the tag. Immutable once created.
        match /friendTags/{tag} {
        allow read: if signedIn();
        allow create: if signedIn()
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
        allow update, delete: if false;
        }

        // ── Friend requests ───────────────────────────────────────────────────────
        match /friendRequests/{id} {
        allow read: if signedIn()
            && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
        allow create: if signedIn()
            && request.resource.data.fromUserId == request.auth.uid;
        allow update: if signedIn()
            && resource.data.toUserId == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined'];
        }

        // ── Friendships ───────────────────────────────────────────────────────────
        match /friendships/{id} {
        allow read: if signedIn()
            && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);
        allow create: if signedIn()
            && request.auth.uid in request.resource.data.users;
        allow update: if false;
        }

        // ── User metrics (leaderboard focus times) ────────────────────────────────
        match /userMetrics/{userId} {
        allow read: if signedIn();
        allow write: if isSelf(userId);
        }

        match /userMetrics/{userId}/daily/{day} {
        allow read: if signedIn();
        allow write: if isSelf(userId);
        }

        // ── Shared objectives ─────────────────────────────────────────────────────
        match /sharedObjectives/{id} {
        allow read: if signedIn()
            && (resource.data.owner_id == request.auth.uid
            || request.auth.uid in resource.data.memberUids);
        allow create: if signedIn()
            && request.resource.data.owner_id == request.auth.uid;
        allow update: if signedIn()
            && (
              // Owner or existing member can update freely
              resource.data.owner_id == request.auth.uid
              || request.auth.uid in resource.data.memberUids
              // Accepted invitee can add themselves (memberUids / members only)
              || (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members'])
                && request.auth.uid in request.resource.data.memberUids
                && !(request.auth.uid in resource.data.memberUids)
              )
            );
        }

        // ── Shared events ─────────────────────────────────────────────────────────
        match /sharedEvents/{id} {
        allow read: if signedIn()
            && (resource.data.creator_id == request.auth.uid
            || request.auth.uid in resource.data.participantUids);
        allow create: if signedIn()
            && request.resource.data.creator_id == request.auth.uid;
        allow update: if signedIn()
            && (
              // Creator or existing participant can update freely
              resource.data.creator_id == request.auth.uid
              || request.auth.uid in resource.data.participantUids
              // Accepted invitee can add themselves (participantUids / participants only)
              || (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantUids', 'participants'])
                && request.auth.uid in request.resource.data.participantUids
                && !(request.auth.uid in resource.data.participantUids)
              )
            );
        }

        // ── Shared invites ────────────────────────────────────────────────────────
        match /sharedInvites/{id} {
        allow read: if signedIn()
            && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
        allow create: if signedIn()
            && request.resource.data.fromUid == request.auth.uid;
        allow update: if signedIn()
            && resource.data.toUid == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        }
    }
    }
