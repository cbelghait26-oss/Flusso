r 5 seconds\r\n    hideTimerRef.current = setTimeout(() => {\r\n      setIsVisible(false);\r\n      Animated.timing(translateY, {\r\n        toValue: 150,\r\n        duration: 300,\r\n        useNativeDriver: true,\r\n      }).start();\r\n    }, 1500);\r\n  })",[9243,9262],"[props.state.index, resetHideTimer]",[1660,1662],"[player]"]