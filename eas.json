{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "credentialsSource": "local",
      "prebuildCommand": "npx expo prebuild --clean && python3 -c \"import plistlib, glob; files=glob.glob('ios/*/Info.plist'); [(__import__('builtins').print('Patching', f), plistlib.dump({k:v for k,v in plistlib.load(open(f,'rb')).items() if k!='UIBackgroundModes'}, open(f,'wb'))) for f in files]; print('Done')\"",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "admin@flussoapp.com",
        "ascAppId": "6759956350",
        "appleTeamId": "BV8B4SJT8T"
      }
    }
  }
}
