{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "credentialsSource": "local",
      "prebuildCommand": "npx expo prebuild --clean && python3 -c \"import plistlib, os; p='ios/Flusso/Info.plist'; d=plistlib.load(open(p,'rb')); d.pop('UIBackgroundModes',None); plistlib.dump(d,open(p,'wb')); print('UIBackgroundModes removed')\"",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "admin@flussoapp.com",
        "ascAppId": "6759956350",
        "appleTeamId": "BV8B4SJT8T"
      }
    }
  }
}
