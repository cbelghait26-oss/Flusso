{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "remote",
      "ios": {
        "bundleIdentifier": "com.BLGgroup.flusso",
        "extensions": [
          {
            "bundleIdentifier": "com.BLGgroup.flusso.FocusLiveActivity",
            "targetName": "FocusLiveActivity"
          }
        ]
      },
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "admin@flussoapp.com",
        "ascAppId": "6759956350",
        "appleTeamId": "BV8B4SJT8T"
      }
    }
  }
}
