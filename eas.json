{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "hooks": {
    "pre-install": "node eas-hooks/pre-install.js"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "credentialsSource": "local",
      "env": {
        "EXPO_NO_DOCTOR": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "admin@flussoapp.com",
        "ascAppId": "6759956350",
        "appleTeamId": "BV8B4SJT8T"
      }
    }
  }
}
